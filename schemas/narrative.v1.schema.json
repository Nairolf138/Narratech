{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narratech.local/schemas/narrative.v1.schema.json",
  "title": "Narratech Narrative Contract V1",
  "description": "Contrat de données V1 pour l'orchestration narrative Narratech (input + output + traçabilité).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "schema_version",
    "input",
    "output",
    "provider_trace"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifiant unique de requête côté orchestrateur."
    },
    "schema_version": {
      "type": "string",
      "const": "narrative.v1",
      "description": "Version figée du contrat de schéma."
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt"],
      "properties": {
        "prompt": {
          "type": "string",
          "minLength": 1,
          "description": "Prompt narratif utilisateur (non vide)."
        },
        "duration_sec": {
          "type": "integer",
          "minimum": 30,
          "maximum": 60,
          "description": "Durée cible V1 (30-60s)."
        },
        "style": {
          "type": "string",
          "minLength": 1,
          "description": "Style visuel/narratif souhaité."
        },
        "language": {
          "type": "string",
          "minLength": 2,
          "description": "Langue de sortie (ex: fr, en)."
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "synopsis",
        "characters",
        "scenes",
        "shots",
        "asset_refs",
        "audio_plan",
        "render_plan"
      ],
      "properties": {
        "synopsis": {
          "type": "string",
          "minLength": 1
        },
        "characters": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "role"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 },
              "role": { "type": "string", "minLength": 1 },
              "description": { "type": "string" }
            }
          }
        },
        "scenes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "summary", "duration_sec"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "summary": { "type": "string", "minLength": 1 },
              "duration_sec": {
                "type": "integer",
                "minimum": 30,
                "maximum": 60
              }
            }
          }
        },
        "shots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "scene_id", "description", "duration_sec"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "scene_id": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "duration_sec": { "type": "number", "exclusiveMinimum": 0 }
            }
          }
        },
        "asset_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "uri"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 },
              "uri": { "type": "string", "minLength": 1 }
            }
          }
        },
        "audio_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["voiceover", "ambience"],
          "properties": {
            "voiceover": {
              "type": "object",
              "additionalProperties": false,
              "required": ["enabled"],
              "properties": {
                "enabled": { "type": "boolean" },
                "language": { "type": "string", "minLength": 2 },
                "script": { "type": "string" }
              }
            },
            "ambience": {
              "type": "object",
              "additionalProperties": false,
              "required": ["enabled"],
              "properties": {
                "enabled": { "type": "boolean" },
                "description": { "type": "string" }
              }
            }
          }
        },
        "render_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["resolution", "fps", "format"],
          "properties": {
            "resolution": { "type": "string", "minLength": 1 },
            "fps": { "type": "integer", "minimum": 1 },
            "format": { "type": "string", "minLength": 1 },
            "transitions": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "provider_trace": {
      "type": "array",
      "description": "Traçabilité des providers invoqués dans le pipeline.",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "provider", "model", "trace_id"],
        "properties": {
          "stage": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "model": { "type": "string", "minLength": 1 },
          "trace_id": { "type": "string", "minLength": 1 },
          "latency_ms": { "type": "integer", "minimum": 0 },
          "fallback_mode": { "type": "boolean" },
          "fallback_reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
